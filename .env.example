# ─── Database (Neon PostgreSQL) ──────────────────────────
# Pooled connection (used by Prisma Client at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/crewconnect?sslmode=require"
# Direct connection (used by Prisma Migrate / db push)
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/crewconnect?sslmode=require"

# ─── Auth ────────────────────────────────────────────────
# Random 64-char secret for JWT signing. Generate with: openssl rand -hex 32
JWT_SECRET="your-secret-here-change-in-production"

# ─── Google OAuth 2.0 ───────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXT_PUBLIC_BASE_URL}/auth/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App ─────────────────────────────────────────────────
# Base URL without trailing slash
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Logging ─────────────────────────────────────────────
# Options: debug, info, warn, error
LOG_LEVEL="debug"

# ─── Vercel Blob (avatar uploads) ────────────────────────
# Get from Vercel dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=""
