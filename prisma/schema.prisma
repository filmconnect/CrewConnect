generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  name         String?
  avatarUrl    String?
  role         String   @default("crew")
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  crewProfile    CrewProfile?
  sessions       Session[]
  passwordResets PasswordReset[]
  sentMessages   Message[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model CrewProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  name                  String
  slug                  String    @unique
  bookingKey            String    @unique
  role                  String
  city                  String?
  country               String
  bio                   String?   @db.Text
  dayRate               Int?
  rateIncludesEquipment Boolean   @default(false)
  equipment             String?   @db.Text
  languages             String?
  avatarUrl             String?
  vimeoUrl              String?
  youtubeUrl            String?
  imdbUrl               String?
  websiteUrl            String?
  legalName             String?
  address               String?
  vatNumber             String?
  iban                  String?
  paymentTerms          String    @default("Net 14")
  plan                  String    @default("free")
  planExpiresAt         DateTime?
  invoiceCounter        Int       @default(0)
  showDayRate           Boolean   @default(true)
  showAvailability      Boolean   @default(true)
  ccRank                Int?
  ccRankUpdatedAt       DateTime?
  claimed               Boolean   @default(true)
  claimedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  clips           VideoClip[]
  credits         Credit[]
  bookings        Booking[]
  blockedDates    BlockedDate[]
  bookingRequests BookingRequest[]
}

model VideoClip {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  description String?
  url         String
  sortOrder   Int      @default(0)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile CrewProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Credit {
  id          String   @id @default(cuid())
  profileId   String
  year        Int
  projectName String
  format      String
  role        String
  director    String?
  agency      String?
  status      String   @default("self")
  addedById   String?
  createdAt   DateTime @default(now())

  profile CrewProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Booking {
  id        String   @id @default(cuid())
  profileId String
  title     String
  client    String?
  startDate DateTime
  endDate   DateTime
  dayRate   Int?
  status    String   @default("confirmed")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile        CrewProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  bookingRequest BookingRequest?
}

model BlockedDate {
  id        String   @id @default(cuid())
  profileId String
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  profile CrewProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
}

model BookingRequest {
  id              String    @id @default(cuid())
  profileId       String
  producerName    String
  producerCompany String?
  producerEmail   String
  producerPhone   String?
  producerVat     String?
  projectName     String
  role            String?
  startDate       DateTime
  endDate         DateTime
  offeredRate     Int
  message         String?   @db.Text
  attachmentUrl   String?
  attachmentName  String?
  attachmentSize  Int?
  status          String    @default("pending")
  confirmationId  String?   @unique
  acceptedAt      DateTime?
  declinedAt      DateTime?
  doneAt          DateTime?
  reviewedByCrewAt DateTime?
  invoiceNumber   Int?
  invoiceIssuedAt DateTime?
  vatRate         Int?
  invoiceUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile   CrewProfile @relation(fields: [profileId], references: [id])
  booking   Booking?    @relation(fields: [bookingId], references: [id])
  bookingId String?     @unique
  messages  Message[]
}

model Message {
  id               String   @id @default(cuid())
  bookingRequestId String
  senderId         String?
  senderName       String
  senderType       String
  content          String   @db.Text
  createdAt        DateTime @default(now())

  bookingRequest BookingRequest @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  sender         User?          @relation(fields: [senderId], references: [id])

  @@index([bookingRequestId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}
